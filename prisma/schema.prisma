generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum ResourceType {
  pdf
  code
  video
  article
  course
  dataset
}

enum ResourceDifficulty {
  beginner
  intermediate
  advanced
}

enum RegistrationStatus {
  registered
  cancelled
  attended
}

enum MembershipStatus {
  pending
  approved
  rejected
}

enum TeamSection {
  executive
  referent
  pole
  mentor
}

enum NotificationType {
  membership
  event
  forum
  activity
  chat
  system
}

enum BlogPostStatus {
  draft
  published
}

enum MemberStatus {
  active
  pending
  approved
}

// ─── Users (sync Clerk) ───────────────────────────────────────────────────────

model User {
  id               String   @id @default(cuid())
  clerkId          String   @unique
  email            String
  firstName        String   @default("")
  lastName         String   @default("")
  role             String   @default("membre")
  roleLevel        Int      @default(1) @map("role_level")
  memberStatus     MemberStatus @default(pending) @map("member_status")
  onboardingDone   Boolean  @default(false) @map("onboarding_done")
  onboardingStep   Int      @default(0) @map("onboarding_step")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  notifications    Notification[]
  pushSubscriptions PushSubscription[]

  @@map("users")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

// ─── Resources ───────────────────────────────────────────────────────────────

model Resource {
  id             String             @id @default(cuid())
  title          String
  description    String
  type           ResourceType
  url            String?
  fileUrl        String?            @map("file_url")
  fileSize       Int?               @map("file_size")
  fileType       String?            @map("file_type")
  thumbnailUrl   String?            @map("thumbnail_url")
  isDownloadable Boolean            @default(false) @map("is_downloadable")
  categoryId     String             @map("category_id")
  tags           String[]           @default([])
  difficulty     ResourceDifficulty @default(beginner)
  author         String?
  duration       String?
  isFeatured     Boolean            @default(false) @map("is_featured")
  isPublished    Boolean            @default(true) @map("is_published")
  viewCount      Int                @default(0) @map("view_count")
  downloadCount  Int                @default(0) @map("download_count")
  createdBy      String             @map("created_by")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  @@index([categoryId, createdAt])
  @@index([isFeatured, isPublished])
  @@map("resources")
}

// ─── Events & Activities (miroir) ────────────────────────────────────────────

model Event {
  id               String   @id @default(cuid())
  title            String
  description      String
  content          String
  categoryId       String   @map("category_id")
  date             DateTime
  endDate          DateTime? @map("end_date")
  location         String
  isOnline         Boolean  @default(false) @map("is_online")
  onlineLink       String?  @map("online_link")
  capacity         Int
  registeredCount  Int      @default(0) @map("registered_count")
  imageUrl         String?  @map("image_url")
  gallery          String[] @default([])
  videoUrls        String[] @default([]) @map("video_urls")
  isPublished      Boolean  @default(false) @map("is_published")
  isFeatured       Boolean  @default(false) @map("is_featured")
  createdBy        String   @map("created_by")
  linkedActivityId String?  @unique @map("linked_activity_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  registrations    EventRegistration[]

  @@index([date, isPublished])
  @@index([categoryId])
  @@map("events")
}

model Activity {
  id                   String   @id @default(cuid())
  title                String
  description          String
  date                 DateTime
  endDate              DateTime? @map("end_date")
  location             String
  isOnline             Boolean  @default(false) @map("is_online")
  onlineLink           String?  @map("online_link")
  registrationDeadline DateTime @map("registration_deadline")
  isMandatory          Boolean  @default(true) @map("is_mandatory")
  isActive             Boolean  @default(true) @map("is_active")
  createdBy            String   @map("created_by")
  createdByName        String   @map("created_by_name")
  linkedEventId        String?  @unique @map("linked_event_id")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  registrations        ActivityRegistration[]
  attendances          Attendance[]

  @@index([date, isActive])
  @@map("activities")
}

model EventRegistration {
  id           String             @id @default(cuid())
  eventId      String             @map("event_id")
  userId       String             @map("user_id")
  userName     String             @map("user_name")
  userEmail    String             @map("user_email")
  status       RegistrationStatus @default(registered)
  registeredAt DateTime           @default(now()) @map("registered_at")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  event        Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@map("event_registrations")
}

model ActivityRegistration {
  id                   String   @id @default(cuid())
  activityId           String   @map("activity_id")
  userId               String   @map("user_id")
  userName             String   @map("user_name")
  userEmail            String   @map("user_email")
  registeredAt         DateTime @default(now()) @map("registered_at")
  registeredBy         String?  @map("registered_by")
  isForcedRegistration Boolean  @default(false) @map("is_forced_registration")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  activity             Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([activityId, userId])
  @@map("activity_registrations")
}

model Attendance {
  id            String   @id @default(cuid())
  activityId    String   @map("activity_id")
  userId        String   @map("user_id")
  userName      String   @map("user_name")
  userEmail     String   @map("user_email")
  isPresent     Boolean  @map("is_present")
  wasRegistered Boolean  @map("was_registered")
  markedBy      String   @map("marked_by")
  markedByName  String   @map("marked_by_name")
  markedAt      DateTime @default(now()) @map("marked_at")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  activity      Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([activityId, userId])
  @@map("attendances")
}

// ─── Forum ───────────────────────────────────────────────────────────────────

model Thread {
  id         String   @id @default(cuid())
  title      String
  content    String
  authorId   String   @map("author_id")
  authorName String   @map("author_name")
  categoryId String   @map("category_id")
  tags       String[] @default([])
  views      Int      @default(0)
  isPinned   Boolean  @default(false) @map("is_pinned")
  isLocked   Boolean  @default(false) @map("is_locked")
  replyCount Int      @default(0) @map("reply_count")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  replies    Reply[]

  @@index([categoryId, createdAt])
  @@map("threads")
}

model Reply {
  id         String   @id @default(cuid())
  threadId   String   @map("thread_id")
  authorId   String   @map("author_id")
  authorName String   @map("author_name")
  content    String
  isEdited   Boolean  @default(false) @map("is_edited")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  thread     Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@map("replies")
}

// ─── Team & Membership ───────────────────────────────────────────────────────

model TeamMember {
  id           String      @id @default(cuid())
  name         String
  role         String
  title        String?
  section      TeamSection
  poleKey      String?     @map("pole_key")
  description  String?
  photoUrl     String?     @map("photo_url")
  linkedin     String?
  github       String?
  twitter      String?
  displayOrder Int         @default(0) @map("display_order")
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  @@index([section, displayOrder])
  @@map("team_members")
}

model MembershipApplication {
  id              String           @id @default(cuid())
  firstName       String           @map("first_name")
  lastName        String           @map("last_name")
  email           String           @unique
  whatsapp        String
  motivations     String
  status          MembershipStatus @default(pending)
  reviewedBy      String?          @map("reviewed_by")
  reviewedAt      DateTime?        @map("reviewed_at")
  rejectionReason String?          @map("rejection_reason")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@map("membership_applications")
}

// ─── Projects (bilingue) ─────────────────────────────────────────────────────

model Project {
  id           String   @id @default(cuid())
  titleEn      String   @map("title_en")
  titleFr      String   @map("title_fr")
  descEn       String   @map("desc_en")
  descFr       String   @map("desc_fr")
  contentEn    String?  @map("content_en")
  contentFr    String?  @map("content_fr")
  imageUrl     String?  @map("image_url")
  status       String?
  techStack    String[] @default([]) @map("tech_stack")
  githubUrl    String?  @map("github_url")
  discoveryUrl String?  @map("discovery_url")
  published    Boolean  @default(false)
  createdBy    String   @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("projects")
}

// ─── Blog ────────────────────────────────────────────────────────────────────

model BlogPost {
  id            String         @id @default(cuid())
  slug          String         @unique
  titleEn       String         @map("title_en")
  titleFr       String         @map("title_fr")
  excerptEn     String         @map("excerpt_en")
  excerptFr     String         @map("excerpt_fr")
  contentEn     String         @map("content_en")
  contentFr     String         @map("content_fr")
  category      String
  imageUrl      String?        @map("image_url")
  authorName    String         @map("author_name")
  status        BlogPostStatus @default(draft)
  publishedAt   DateTime?      @map("published_at")
  linkedEventId String?        @unique @map("linked_event_id")
  createdBy     String         @map("created_by")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@index([status, publishedAt])
  @@map("blog_posts")
}

// ─── Partners ────────────────────────────────────────────────────────────────

model Partner {
  id          String   @id @default(cuid())
  name        String
  description String?
  logoUrl     String?  @map("logo_url")
  websiteUrl  String?  @map("website_url")
  type        String   @default("partner")
  displayOrder Int     @default(0) @map("display_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("partners")
}

// ─── Notifications ─────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}
