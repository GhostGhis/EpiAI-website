{
  "name": "epi_ai_website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NEXT_DISABLE_TURBOPACK=1 next dev -p 3002",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:seed": "dotenv -e .env.local -- tsx scripts/seed.ts",
    "db:seed:team": "dotenv -e .env.local -- tsx scripts/seed-team.ts",
    "db:seed:projects": "dotenv -e .env.local -- tsx scripts/seed-projects.ts",
    "db:seed:projects:prod": "tsx scripts/seed-projects.ts",
    "db:seed:resources": "dotenv -e .env.local -- tsx scripts/seed-resources.ts",
    "db:seed:resources:prod": "tsx scripts/seed-resources.ts",
    "db:seed:talks": "dotenv -e .env.local -- tsx scripts/seed-talks.ts",
    "db:seed:talks:prod": "tsx scripts/seed-talks.ts",
    "db:migrate-roles": "dotenv -e .env.local -- tsx scripts/migrate-member-role.ts",
    "db:deploy": "prisma db push",
    "test": "vitest run",
    "push:vapid": "node -e \"const w=require('web-push');const k=w.generateVAPIDKeys();console.log('VAPID_PUBLIC_KEY='+k.publicKey);console.log('VAPID_PRIVATE_KEY='+k.privateKey);console.log('NEXT_PUBLIC_VAPID_PUBLIC_KEY='+k.publicKey);\"",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.36.5",
    "@clerk/themes": "^2.4.46",
    "@next/swc-linux-x64-gnu": "^16.1.6",
    "@prisma/client": "^5.22.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.562.0",
    "next": "^16.1.6",
    "next-intl": "^4.6.1",
    "prisma": "^5.22.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.6.0",
    "stream-chat": "^9.35.1",
    "stream-chat-react": "^13.14.1",
    "svix": "^1.96.0",
    "tailwind-merge": "^3.4.0",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "mongodb": "^7.0.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^3.2.6"
  }
}
