# PostgreSQL (Prisma)
DATABASE_URL=postgresql://epiai:epiai_dev@localhost:5432/epiai

# Legacy MongoDB (migration script only — optional)
MONGODB_URI=mongodb://localhost:27017
DATABASE=Epi'AI

# Clerk (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Resend (emails d'adhésion)
RESEND_API_KEY=re_...
# Domaine vérifié dans Resend (sinon onboarding@resend.dev = test uniquement)
RESEND_FROM_EMAIL=Epi'AI <membership@epiai.eu>

# Site
NEXT_PUBLIC_SITE_URL=https://epiai.eu

# Cron (rappels événements J-1) — Vercel Cron ou curl manuel
CRON_SECRET=your-random-secret

# Sentry (optionnel)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Stream Chat (optionnel — /fr/chat)
NEXT_PUBLIC_STREAM_API_KEY=
STREAM_API_SECRET=

# Chatbot assistant (OpenAI ou Gemini via couche compatible OpenAI)
# OpenAI : OPENAI_API_KEY=sk-...  +  OPENAI_CHATBOT_MODEL=gpt-4o-mini
# Gemini : OPENAI_API_KEY=<clé Google AI Studio>  +  OPENAI_CHATBOT_MODEL=gemini-2.5-flash
# (ou GEMINI_API_KEY à la place de OPENAI_API_KEY)
OPENAI_API_KEY=
OPENAI_CHATBOT_MODEL=gpt-4o-mini
# CHATBOT_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
